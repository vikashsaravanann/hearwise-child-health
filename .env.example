# =====================
# SUPABASE CONFIGURATION
# =====================
# Get from: supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =====================
# ADMIN ACCESS
# =====================
# Email of the admin user (only this email can access the dashboard)
VITE_ADMIN_EMAIL=your_admin_email@example.com
# Admin password for the dashboard login gate
VITE_ADMIN_PASSWORD=your_secure_admin_password

# =====================
# GOOGLE OAUTH
# =====================
# Get from: console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# =====================
# AI CHATBOT (HEARBOT)
# =====================
# Get from: console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-your_key_here

# =====================
# BUILD ENVIRONMENT
# =====================
# Set automatically by Vercel — do NOT set this manually
# VERCEL=1
