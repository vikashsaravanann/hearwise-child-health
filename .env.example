# ---------------------------------------------------------------------------
# HearWise — Environment Variables
# Copy this file to `.env` and fill in the values.
# NEVER commit .env to source control — add it to .gitignore.
# ---------------------------------------------------------------------------

# --- Supabase (required) ---
# Find these in your Supabase project → Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# --- Admin portal (required) ---
# Only this email can access /admin and /dashboard.
# Any other email will be shown "Access Denied. Unauthorized user."
# SECURITY: This is the first-layer guard. Server-side RLS via admin_users
# table is the authoritative enforcement layer.
VITE_ADMIN_EMAIL=your-admin-email@example.com

# --- Error tracking (optional) ---
# Create a project at https://sentry.io and paste the DSN here.
# SECURITY: Never hardcode a Sentry DSN in source — always use this variable.
# Leave empty to disable Sentry entirely.
VITE_SENTRY_DSN=

# --- Product analytics (optional) ---
# Create a project at https://posthog.com and paste the project key here.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
